; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SUPER GODOT TEST 64"
run/main_scene="res://logo.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 0)
boot_splash/show_image=false
boot_splash/stretch_mode=0
boot_splash/use_filter=false
config/icon="res://icon.svg"

[autoload]

Global_self="*uid://bfaok257q5vqi"

[debug]

settings/stdout/print_fps=true

[display]

window/frame_pacing/android/swappy_mode=0
display_server/driver.windows="windows"
display_server/driver.linuxbsd="x11"
display_server/driver.android="android"
display_server/driver.ios="iOS"
display_server/driver.visionos="visionOS"
display_server/driver.macos="macos"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="testing"

[editor]

movie_writer/disable_vsync=true
version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/optiscene/plugin.cfg", "res://addons/virtual_joystick/plugin.cfg")

[importer_defaults]

animation_library={
&"animation/fps": 120.0,
&"fbx/allow_geometry_helper_nodes": true
}

